# Copy this file to .env for local development.
# On your hosting provider (Render, Railway, etc.), set these as
# environment variables in the dashboard instead of using this file.

# Any long, random string — used to sign login sessions.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Most hosts set PORT for you automatically; only needed for local runs.
PORT=4000
